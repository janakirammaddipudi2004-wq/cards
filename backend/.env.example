# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cards_game
# Use true for external managed Postgres providers that require SSL.
DATABASE_SSL=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=1234567890-example.apps.googleusercontent.com
# Not required by this app's current Google ID-token verification flow.
GOOGLE_CLIENT_SECRET=

# Frontend URL for CORS. Use commas for multiple deployed frontend URLs.
FRONTEND_URL=http://localhost:5173
